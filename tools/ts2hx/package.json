{
  "name": "@genes-ts/ts2hx",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Experimental TS/JS → Haxe transpiler (ts2hx).",
  "bin": {
    "ts2hx": "./dist/cli.js"
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "prets2hx": "yarn build",
    "ts2hx": "node dist/cli.js",
    "test:snapshots": "yarn build && node dist/test-snapshots.js",
    "test:roundtrip": "yarn build && node dist/test-roundtrip.js",
    "test:strict-diagnostics": "yarn build && node dist/test-strict-diagnostics.js",
    "test": "yarn test:snapshots && yarn test:roundtrip && yarn test:strict-diagnostics"
  }
}
