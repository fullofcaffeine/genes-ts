{
  "name": "@genes-ts/ts2hx",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Experimental TS/JS → Haxe transpiler (ts2hx).",
  "bin": {
    "ts2hx": "./dist/cli.js"
  },
  "scripts": {
    "build": "node ../../scripts/run-typescript.mjs apiBridge -p tsconfig.json",
    "prets2hx": "yarn build",
    "ts2hx": "node dist/cli.js",
    "test:snapshots": "yarn build && node dist/test-snapshots.js",
    "test:roundtrip": "yarn build && node dist/test-roundtrip.js",
    "test:semantic-diff": "yarn build && node dist/test-semantic-diff.js",
    "test:strict-diagnostics": "yarn build && node dist/test-strict-diagnostics.js",
    "test": "yarn test:snapshots && yarn test:roundtrip && yarn test:semantic-diff && yarn test:strict-diagnostics"
  }
}
