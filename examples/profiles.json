{
  "schemaVersion": 1,
  "examples": {
    "todoapp": {
      "sourceRoots": ["examples/todoapp/src"],
      "profiles": {
        "ts-strict": {
          "build": "yarn build:example:todoapp",
          "runtime": "node scripts/dist/qa-todoapp.js --profile ts",
          "playwright": "node scripts/dist/qa-todoapp.js --profile ts --playwright"
        },
        "classic-esm": {
          "build": "yarn build:example:todoapp:classic",
          "runtime": "node scripts/dist/qa-todoapp.js --profile classic",
          "playwright": "node scripts/dist/qa-todoapp.js --profile classic --playwright"
        }
      }
    },
    "typescript-target": {
      "sourceRoots": ["examples/typescript-target/src"],
      "profiles": {
        "ts-strict": {
          "build": "yarn build:example:genes-ts",
          "runtime": "examples/typescript-target/dist/index.js"
        },
        "classic-esm": {
          "build": "yarn build:example:genes-ts",
          "runtime": "examples/typescript-target/classic-src-gen/index.js"
        }
      }
    }
  }
}
