{
  "schemaVersion": 2,
  "examples": {
    "todoapp": {
      "sourceRoots": ["examples/todoapp/src"],
      "profiles": {
        "ts-strict": {
          "build": {
            "command": "node",
            "args": ["scripts/dist/build-example-todoapp.js"]
          },
          "runtime": {
            "command": "node",
            "args": [
              "scripts/dist/qa-todoapp.js",
              "--profile",
              "ts",
              "--skip-build"
            ]
          },
          "playwright": {
            "command": "node",
            "args": [
              "scripts/dist/qa-todoapp.js",
              "--profile",
              "ts",
              "--skip-build",
              "--playwright"
            ]
          }
        },
        "classic-esm": {
          "build": {
            "command": "node",
            "args": ["scripts/dist/build-example-todoapp-classic.js"]
          },
          "runtime": {
            "command": "node",
            "args": [
              "scripts/dist/qa-todoapp.js",
              "--profile",
              "classic",
              "--skip-build"
            ]
          },
          "playwright": {
            "command": "node",
            "args": [
              "scripts/dist/qa-todoapp.js",
              "--profile",
              "classic",
              "--skip-build",
              "--playwright",
              "--skip-playwright-install"
            ]
          }
        }
      }
    },
    "typescript-target": {
      "sourceRoots": ["examples/typescript-target/src"],
      "profiles": {
        "ts-strict": {
          "build": {
            "command": "node",
            "args": ["scripts/dist/build-example-typescript-target.js"]
          },
          "runtime": {
            "command": "node",
            "args": ["examples/typescript-target/dist/index.js"]
          }
        },
        "classic-esm": {
          "build": {
            "command": "node",
            "args": ["scripts/dist/build-example-typescript-target.js"]
          },
          "runtime": {
            "command": "node",
            "args": ["examples/typescript-target/classic-src-gen/index.js"]
          }
        }
      }
    }
  }
}
