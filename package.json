    "build:scripts": "node scripts/run-typescript.mjs apiBridge -p scripts/tsconfig.json",
    "beads:export": "yarn build:scripts && node scripts/dist/export-beads-snapshot.js",
    "test:beads-worktrees": "yarn build:scripts && node scripts/dist/test-beads-worktree-safety.js",
    "test:versions": "yarn build:scripts && node scripts/dist/check-versions.js",
    "report:compatibility": "yarn build:scripts && node scripts/dist/compatibility-report.js",
    "test:compatibility-report": "yarn build:scripts && node scripts/dist/compatibility-report.js --check && node scripts/dist/test-downstream-runner-policy.js && node scripts/dist/test-downstream-contracts.js",
    "test:downstream:contracts": "yarn build:scripts && node scripts/dist/test-downstream-runner-policy.js && node scripts/dist/test-downstream-contracts.js",
    "test:downstream:curated": "yarn build:scripts && node scripts/dist/test-downstream-contracts.js",
    "test:types:exports": "yarn build:scripts && node scripts/dist/test-exported-surface-policy.js",
    "test:interop:module-shapes": "yarn build:scripts && node scripts/dist/test-package-shapes.js",
    "test:binding-identity": "yarn build:scripts && node scripts/dist/probe-binding-identity.js",
    "probe:binding-identity": "yarn test:binding-identity",
    "test:ts-narrowing": "yarn build:scripts && node scripts/dist/test-ts-narrowing.js",
    "test:hxx-carrier-immutability": "yarn build:scripts && node scripts/dist/test-hxx-carrier-immutability.js",
    "test:hxx-event-variance": "yarn build:scripts && node scripts/dist/test-hxx-event-variance.js",
    "test:classic:dts": "yarn build:scripts && node scripts/dist/test-classic-dts.js",
    "test:library-profile": "yarn build:scripts && node scripts/dist/test-library-profile.js",
    "test:dual-output": "yarn build:scripts && node scripts/dist/test-output-modes.js && node scripts/dist/test-string-literals.js && node scripts/dist/test-template-literals.js && node scripts/dist/test-async-await-evidence.js && node scripts/dist/test-output-quality.js && node scripts/dist/test-output-transaction.js && node scripts/dist/test-internal-types.js && node scripts/dist/test-array-index-strict.js && node scripts/dist/test-finally-completion.js",
    "test:string-literals": "yarn build:scripts && node scripts/dist/test-string-literals.js",
    "test:template-literals": "yarn build:scripts && node scripts/dist/test-template-literals.js",
    "test:async-await:evidence": "yarn build:scripts && node scripts/dist/test-async-await-evidence.js",
    "test:output-quality": "yarn build:scripts && node scripts/dist/test-output-quality.js",
    "test:output-transaction": "yarn build:scripts && node scripts/dist/test-output-transaction.js",
    "test:side-effect-import:evidence": "yarn build:scripts && node scripts/dist/test-side-effect-import-evidence.js",
    "test:module-directives": "yarn build:scripts && node scripts/dist/test-module-directives.js",
    "test:internal-types": "yarn build:scripts && node scripts/dist/test-internal-types.js",
    "test:type-roots": "yarn build:scripts && node scripts/dist/test-type-roots.js",
    "test:finally-completion": "yarn build:scripts && node scripts/dist/test-finally-completion.js",
    "test:deep-nullish-alias": "yarn build:scripts && node scripts/dist/test-deep-nullish-alias.js",
    "benchmark:dependency-plan": "yarn build:scripts && node scripts/dist/benchmark-dependency-plan.js",
    "test:ts2hx-bootstrap": "yarn build:scripts && node scripts/dist/test-ts2hx-bootstrap.js",
    "test:matrix:generated": "yarn build:scripts && node scripts/dist/test-genes-ts-full.js && node scripts/dist/test-genes-tsx.js && node scripts/dist/test-package-shapes.js && node scripts/dist/probe-binding-identity.js && node scripts/dist/test-ts-narrowing.js && node scripts/dist/test-hxx-carrier-immutability.js && node scripts/dist/test-hxx-event-variance.js && node scripts/dist/test-output-modes.js && node scripts/dist/test-string-literals.js && node scripts/dist/test-template-literals.js && node scripts/dist/test-async-await-evidence.js && node scripts/dist/test-output-quality.js && node scripts/dist/test-output-transaction.js && node scripts/dist/test-side-effect-import-evidence.js && node scripts/dist/test-module-directives.js && node scripts/dist/test-internal-types.js && node scripts/dist/test-type-roots.js && node scripts/dist/test-array-index-strict.js && node scripts/dist/test-finally-completion.js && node scripts/dist/test-deep-nullish-alias.js && node scripts/dist/test-classic-dts.js && node scripts/dist/test-library-profile.js",
