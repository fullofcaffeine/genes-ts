    "example:todoapp:classic:run": "cross-env TODOAPP_WEB_DIST=examples/todoapp/web/classic-dist node examples/todoapp/server/classic-src-gen/index.js",
    "build:todoapp:e2e": "yarn build:scripts && node scripts/dist/build-todoapp-e2e.js",
    "test:examples": "yarn build:scripts && node scripts/dist/test-examples.js",
    "test:todoapp": "yarn build:scripts && node scripts/dist/qa-todoapp.js",
    "test:todoapp:e2e": "yarn build:scripts && node scripts/dist/qa-todoapp.js --playwright",
    "postinstall": "lix download"
  },
  "devDependencies": {
    "@playwright/test": "1.58.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "bestzip": "2.2.1",
    "cross-env": "^10.1.0",
    "dts2hx": "0.34.0",
    "express": "^4.22.2",
    "lix": "^16.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4",
    "rimraf": "^6.1.2",
    "source-map": "0.6.1",
    "@typescript/legacy": "npm:typescript@5.5.4",
    "@typescript/native": "npm:typescript@7.0.2",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "semantic-release": "^24.2.9"
  },
  "resolutions": {
    "@typescript/old": "npm:typescript@6.0.3",
    "handlebars": "4.7.9",
    "ip-address": "10.2.0",
    "js-yaml": "4.2.0",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "minimatch": "10.2.5",
    "path-to-regexp": "0.1.13",
    "picomatch": "4.0.4",
    "qs": "6.15.2",
    "@sigstore/core": "3.2.1",
    "sigstore": "4.1.1",
    "tar": "7.5.16"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "node scripts/dist/release/sync-versions.js ${nextRelease.version} && yarn submit:zip"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "yarn.lock",
            "haxelib.json",
            "readme.md",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\\n\\n${nextRelease.notes}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "submit.zip",
              "label": "haxelib package (submit.zip)"
            }
          ]
        }
      ]
    ]
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
