-lib helder.set

-cp src
-cp tests/genes-ts/no-js-es/src
--main Main

# Exercise `-D genes.ts` without the library extraParams `js-es=6` define.
# Downstream dev checkouts can resolve genes-ts this way through haxelib paths.
-js tests/genes-ts/no-js-es/out/src-gen/index.ts
-D genes.ts
-D genes.ts.lower_private_helpers

--macro genes.Generator.use()
--macro genes.js.Async.enable()
--macro genes.react.InlineMarkup.enable()
--macro addMetadata('@:genes.disableNativeAccessors', 'haxe.Exception')

-dce full
