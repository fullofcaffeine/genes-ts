{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "types": ["node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": "./out/ts/src-gen",
    "outDir": "./out/ts/dist",
    "verbatimModuleSyntax": true,
    "skipLibCheck": false,
    "noEmitOnError": true
  },
  "include": ["out/ts/src-gen/**/*.ts"]
}
