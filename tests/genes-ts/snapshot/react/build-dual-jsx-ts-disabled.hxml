-lib genes-ts

-cp tests/genes-ts/snapshot/react/src
--main DualJsxMain

# This contradictory profile must fail before publishing output: `.jsx`
# erases Haxe types, while `genes.ts` promises to preserve them.
-js tests/genes-ts/snapshot/react/out/dual-jsx-ts-disabled/index.jsx
-D genes.ts
-D genes.react.inline_markup
-D js-es=6

-dce full
