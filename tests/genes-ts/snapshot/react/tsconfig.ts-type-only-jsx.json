{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "types": ["node", "react"],
    "declaration": true,
    "rootDir": "./out/ts-type-only-jsx/src-gen",
    "outDir": "./out/ts-type-only-jsx/dist",
    "verbatimModuleSyntax": true,
    "skipLibCheck": false
  },
  "include": [
    "out/ts-type-only-jsx/src-gen/**/*.ts"
  ]
}
