{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "sourceMap": true,
    "types": [],
    "rootDir": "./out/ts/src-gen",
    "outDir": "./out/ts/dist",
    "verbatimModuleSyntax": true,
    "skipLibCheck": false
  },
  "include": ["out/ts/src-gen/**/*.ts"]
}
