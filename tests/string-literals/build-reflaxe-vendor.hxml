-lib helder.set
-cp ../haxe.elixir.codex/vendor/genes/src
-cp tests/string-literals/src
--main literalevidence.Main
-js tests/string-literals/out/reflaxe-vendor/index.js
-D no-deprecation-warnings
-D js-es=6
-dce full
-debug
--macro genes.Generator.use()
--macro addMetadata('@:genes.disableNativeAccessors', 'haxe.Exception')
