{
  "schemaVersion": 1,
  "contract": "genes-ts-compatibility-evidence",
  "statement": "genes-ts supports controlled Haxe-to-TypeScript and classic ESM JavaScript profiles. This evidence inventory maps bounded claims to exact gates; it is not a blanket certification of arbitrary Haxe or npm programs.",
  "statusSemantics": {
    "blocking": "The named gate is required by core CI/release.",
    "nonblockingNightly": "The named pressure test reports evidence without blocking core changes.",
    "liveResultLocation": "GitHub Actions; this deterministic file is not a cached run log."
  },
  "classes": [
    {
      "id": "compile_inventory",
      "label": "Compile inventory",
      "meaning": "Sources and declared profiles compile under their owned gates; compilation alone is not semantic or public-type proof."
    },
    {
      "id": "strict_public_typing",
      "label": "Strict public typing",
      "meaning": "Positive consumers compile and selected invalid consumers are rejected without broad public any/unknown/index signatures."
    },
    {
      "id": "semantic_differential",
      "label": "Semantic differential",
      "meaning": "Named runtime traces agree across the explicitly listed oracles; the result applies only to those contracts."
    },
    {
      "id": "snapshot",
      "label": "Snapshot stability",
      "meaning": "Generated source shape is deterministic relative to reviewed snapshots; snapshots do not establish semantics by themselves."
    },
    {
      "id": "smoke",
      "label": "Runtime smoke and E2E",
      "meaning": "Named application journeys execute in selected profiles; smoke success is not general semantic parity."
    },
    {
      "id": "toolchain",
      "label": "Toolchain compatibility",
      "meaning": "Generated output and programmatic compiler APIs are checked on separately owned, pinned lanes."
    },
    {
      "id": "package_shape",
      "label": "Package-shape interoperability",
      "meaning": "Named ESM, subpath, conditional-export, CommonJS, and declaration-ingestion fixtures work under their tested resolution modes."
    },
    {
      "id": "downstream",
      "label": "Downstream pressure tests",
      "meaning": "Pinned WIP consumers provide nonblocking integration evidence; failures are not compiler defects until reduced to a generic compiler fixture."
    }
  ],
  "buckets": [
    {
      "id": "compiler-output-inventory",
      "class": "compile_inventory",
      "label": "Classic JavaScript and TypeScript output inventory",
      "disposition": "blocking",
      "scope": "Classic Genes runtime tests, generated TypeScript snapshot profiles, and every checked-in example in both first-class output profiles.",
      "evidence": [
        "test.hxml",
        "scripts/test-acceptance.ts",
        "scripts/test-examples.ts",
        "tests/genes-ts/snapshot",
        "examples/profiles.json"
      ],
      "commands": [
        "yarn test",
        "yarn test:acceptance"
      ],
      "metrics": [
        {
          "id": "classic-test-modules",
          "label": "Classic Haxe test modules",
          "kind": "tracked-files",
          "path": "tests",
          "match": "^Test[^/]*\\.hx$",
          "expected": 46,
          "count": 46
        },
        {
          "id": "genes-ts-snapshot-profiles",
          "label": "Generated TypeScript snapshot profiles",
          "kind": "source-pattern",
          "path": "scripts/test-genes-ts-snapshots.ts",
          "match": "\\n\\s*name:\\s*\"",
          "expected": 7,
          "count": 7
        },
        {
          "id": "checked-in-examples",
          "label": "Examples with TS and classic profiles",
          "kind": "json-object-keys",
          "path": "examples/profiles.json",
          "pointer": [
            "examples"
          ],
          "expected": 2,
          "count": 2
        }
      ],
      "proves": "The enumerated compiler fixtures and examples compile under their owned TS/classic profiles.",
      "doesNotProve": "Compilation does not prove closed public types, runtime equivalence, or arbitrary ecosystem compatibility."
    },
    {
      "id": "public-type-safety",
      "class": "strict_public_typing",
      "label": "Closed exported surfaces and strict declaration consumers",
      "disposition": "blocking",
      "scope": "Generated TS exports, ordinary interfaces, explicit foreign boundaries, classic declarations, and strict external consumers.",
      "evidence": [
        "scripts/exported-surface-policy.ts",
        "scripts/test-exported-surface-policy.ts",
        "scripts/test-classic-dts.ts",
        "scripts/test-library-profile.ts",
        "tests/typing-policy/exported-surface-boundaries.json",
        "tests/typing-policy/semantic",
        "tests/classic-dts/consumer.ts",
        "tests/output-modes/consumer.ts",
        "tests/library-profile/consumer.ts",
        "tests/library-profile/src"
      ],
      "commands": [
        "yarn test:types:exports",
        "yarn test:classic:dts",
        "yarn test:dual-output",
        "yarn test:library-profile"
      ],
      "metrics": [
        {
          "id": "strict-consumer-sources",
          "label": "Strict positive/negative consumer sources",
          "kind": "tracked-files",
          "path": "tests",
          "match": "^(typing-policy/semantic/[^/]+|classic-dts/consumer|output-modes/consumer|library-profile/consumer)\\.ts$",
          "expected": 7,
          "count": 7
        },
        {
          "id": "owned-unsafe-boundaries",
          "label": "Explicitly owned exported-surface boundaries",
          "kind": "json-array",
          "path": "tests/typing-policy/exported-surface-boundaries.json",
          "pointer": [
            "boundaries"
          ],
          "expected": 6,
          "count": 6
        },
        {
          "id": "reusable-library-source-modules",
          "label": "Reusable-library same-source Haxe modules",
          "kind": "tracked-files",
          "path": "tests/library-profile/src",
          "match": "\\.hx$",
          "expected": 4,
          "count": 4
        }
      ],
      "proves": "Selected exported APIs are semantically audited, strict consumers reject the named unsafe programs, and one opt-in library graph has matched retained TS/classic runtime and declaration surfaces.",
      "doesNotProve": "The audit cannot infer soundness for untested raw metadata or every third-party declaration package."
    },
    {
      "id": "runtime-semantic-differentials",
      "class": "semantic_differential",
      "label": "Same-source compiler and ts2hx semantic differentials",
      "disposition": "blocking",
      "scope": "Haxe-to-TS/classic evaluation traces plus ts2hx strict-js contracts against original TypeScript.",
      "evidence": [
        "tests/output-modes/profile-ownership.json",
        "tests/output-modes/expected-trace.json",
        "tests/output-modes/src",
        "scripts/test-output-modes.ts",
        "tools/ts2hx/fixtures/semantic-diff",
        "tools/ts2hx/fixtures/semantic-module-boundaries",
        "tools/ts2hx/fixtures/semantic-unsupported",
        "tools/ts2hx/src/test-semantic-diff.ts",
        "tools/ts2hx/src/test-runtime-profile.ts"
      ],
      "commands": [
        "yarn test:dual-output",
        "yarn --cwd tools/ts2hx test:semantic-diff",
        "yarn --cwd tools/ts2hx test:runtime-profile"
      ],
      "metrics": [
        {
          "id": "dual-output-source-modules",
          "label": "Same-source Haxe modules",
          "kind": "tracked-files",
          "path": "tests/output-modes/src",
          "match": "\\.hx$",
          "expected": 12,
          "count": 12
        },
        {
          "id": "dual-output-oracles-and-profiles",
          "label": "TS/classic/declaration and JS oracle profiles",
          "kind": "json-array",
          "path": "tests/output-modes/profile-ownership.json",
          "pointer": [
            "profiles"
          ],
          "expected": 5,
          "count": 5
        },
        {
          "id": "dual-output-trace-events",
          "label": "Stable dual-output runtime trace events",
          "kind": "json-array-total",
          "path": "tests/output-modes/expected-trace.json",
          "pointer": [],
          "expected": 19,
          "count": 19
        },
        {
          "id": "ts2hx-semantic-input-modules",
          "label": "ts2hx supported and fail-closed semantic input modules",
          "kind": "tracked-files",
          "path": "tools/ts2hx/fixtures",
          "match": "^semantic-(diff|unsupported|module-boundaries)/src/.*\\.ts$",
          "expected": 53,
          "count": 53
        }
      ],
      "proves": "Named traces preserve evaluation order and runtime behavior across the listed Haxe/TypeScript oracles, named unsupported ts2hx semantics fail closed, and an effective ESM request cannot cross into standard Haxe silently.",
      "doesNotProve": "The curated traces are not a language-wide proof or a promise of portable ts2hx output on non-JS targets."
    },
    {
      "id": "reviewed-generated-shape",
      "class": "snapshot",
      "label": "Reviewed genes-ts and ts2hx snapshots",
      "disposition": "blocking",
      "scope": "Generated TypeScript/TSX and supported ts2hx Haxe source shapes.",
      "evidence": [
        "scripts/test-genes-ts-snapshots.ts",
        "tests/genes-ts/snapshot",
        "tools/ts2hx/src/test-snapshots.ts",
        "tools/ts2hx/tests_snapshots"
      ],
      "commands": [
        "yarn test:genes-ts:snapshots",
        "yarn --cwd tools/ts2hx test:snapshots"
      ],
      "metrics": [
        {
          "id": "genes-ts-snapshot-profiles",
          "label": "genes-ts snapshot profiles",
          "kind": "source-pattern",
          "path": "scripts/test-genes-ts-snapshots.ts",
          "match": "\\n\\s*name:\\s*\"",
          "expected": 7,
          "count": 7
        },
        {
          "id": "ts2hx-snapshot-files",
          "label": "ts2hx reviewed snapshot files",
          "kind": "tracked-files",
          "path": "tools/ts2hx/tests_snapshots",
          "match": ".*",
          "expected": 48,
          "count": 48
        }
      ],
      "proves": "The exact generated forms remain stable unless reviewers intentionally update their baselines.",
      "doesNotProve": "A stable snapshot can preserve a bug; semantic and typing gates remain authoritative."
    },
    {
      "id": "same-source-example-smoke",
      "class": "smoke",
      "label": "Same-source examples and todoapp browser E2E",
      "disposition": "blocking",
      "scope": "The minimal example and fullstack todoapp compile from one Haxe source tree through TS and classic ESM profiles.",
      "evidence": [
        "examples/profiles.json",
        "examples/typescript-target/src",
        "examples/todoapp/src",
        "examples/todoapp/e2e/src/todo/e2e/Main.hx",
